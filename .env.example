# Local environment reference.
# Copy this file to .env only when you need local configuration.
# Do not commit real tokens, API keys, passwords or production secrets.

VITE_API_BASE_URL=
VITE_BACKEND_ENABLED=false
VITE_DEMO_MODE=true
VITE_OPENWEATHER_API_KEY=

# Do not place ADMIN_API_TOKEN here.
# VITE variables are exposed to the browser.
# ADMIN_API_TOKEN must be configured only as a Cloudflare Pages secret/environment variable for Functions.
